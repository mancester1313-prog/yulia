function doCopy(){
  var txt=document.getElementById('rtxt').textContent;
  var msg=document.getElementById('cmsg');
  function ok(){msg.textContent='✅ Скопійовано!';setTimeout(function(){msg.textContent='';},2500);}
  if(navigator.clipboard&&navigator.clipboard.writeText){navigator.clipboard.writeText(txt).then(ok).catch(function(){fb(txt,ok);});}
  else fb(txt,ok);
}
function fb(txt,cb){var ta=document.createElement('textarea');ta.value=txt;ta.style.cssText='position:fixed;opacity:0;top:0';document.body.appendChild(ta);ta.focus();ta.select();try{document.execCommand('copy');}catch(e){}document.body.removeChild(ta);cb();}
function goBack(){
  var d=S.rt==='week'?'week':S.rt==='prog'?'prog':S.cur;
  var idx={tue:0,thu:1,fri:2,sun:3,week:4,prog:5}[d]||0;
  document.querySelectorAll('.tab').forEach(function(t,i){t.classList.toggle('on',i===idx);});
  if(d==='week')rWeek();else if(d==='prog')rProg();else rDay(d);
}
function rProg(){
  var h='<div class="lbl">Вага (кг) по тижнях</div><div class="card"><div class="cw"><canvas id="cw"></canvas></div></div>';
  h+='<div class="lbl">Hip Thrust (кг)</div><div class="card"><div class="cw"><canvas id="cht"></canvas></div></div>';
  h+='<div class="lbl">Румунська тяга (кг)</div><div class="card"><div class="cw"><canvas id="crdl"></canvas></div></div>';
  document.getElementById('main').innerHTML=h;
  var wks=['Тиж1','Тиж2','Тиж3','Тиж4','Тиж5','Тиж6','Тиж7','Тиж8'];
  var cw=S.wk.w||85;
  var cht=(S.d['thu']&&S.d['thu'].w&&S.d['thu'].w[1])||60;
  var crdl=(S.d['thu']&&S.d['thu'].w&&S.d['thu'].w[0])||40;
  dChart('cw',[88,87.5,87,86.5,86,85.8,85.3,cw],'#C9A84C',wks);
  dChart('cht',[40,45,50,52,55,57,55,cht],'#2563eb',wks);
  dChart('crdl',[25,28,32,35,37,38,35,crdl],'#22c55e',wks);
}
function dChart(id,data,color,labels){
  var cv=document.getElementById(id);if(!cv)return;
  var pw=cv.parentElement;
  var W=pw?pw.offsetWidth||300:300,H=150;
  cv.width=W;cv.height=H;
  var ctx=cv.getContext('2d');
  if(!ctx)return;
  var p={t:18,r:14,b:26,l:36};
  var cW=W-p.l-p.r,cH=H-p.t-p.b;
  var mn=Math.min.apply(null,data)-3,mx=Math.max.apply(null,data)+3;
  ctx.clearRect(0,0,W,H);
  for(var g=0;g<4;g++){
    var gy=p.t+cH*(g/3);
    ctx.strokeStyle='rgba(255,255,255,0.04)';ctx.lineWidth=1;
    ctx.beginPath();ctx.moveTo(p.l,gy);ctx.lineTo(p.l+cW,gy);ctx.stroke();
    ctx.fillStyle='rgba(255,255,255,0.3)';ctx.font='9px Arial';ctx.textAlign='right';
    ctx.fillText(Math.round(mx-(mx-mn)*g/3),p.l-3,gy+3);
  }
  ctx.beginPath();
  data.forEach(function(v,i){var x=p.l+cW*i/(data.length-1);var y=p.t+cH*(1-(v-mn)/(mx-mn));i===0?ctx.moveTo(x,y):ctx.lineTo(x,y);});
  ctx.strokeStyle=color;ctx.lineWidth=2;ctx.lineJoin='round';ctx.lineCap='round';ctx.stroke();
  data.forEach(function(v,i){
    var x=p.l+cW*i/(data.length-1);var y=p.t+cH*(1-(v-mn)/(mx-mn));
    var last=i===data.length-1;
    ctx.beginPath();ctx.arc(x,y,last?5:3,0,Math.PI*2);
    ctx.fillStyle=last?color:'rgba(255,255,255,0.5)';ctx.fill();
    if(last){ctx.fillStyle=color;ctx.font='bold 10px Arial';ctx.textAlign='center';ctx.fillText(v,x,y-8);}
    ctx.fillStyle='rgba(255,255,255,0.25)';ctx.font='9px Arial';ctx.textAlign='center';
    if(i%2===0||last)ctx.fillText(labels[i],x,H-3);
  });
}
function rTrainer(){
  var days=['tue','thu','fri','sun'];
  var h='<div class="lbl">Панель тренера — Тиждень '+W+'</div>';
  days.forEach(function(day){
    iDay(day);
    var d=S.d[day],ex=EX[day]||[],dn=DN[day];
    var tot=0,done=0;
    ex.forEach(function(e,i){if(d.sets[i])d.sets[i].forEach(function(s){tot++;if(s==='done')done++;});});
    var pct=tot>0?Math.round(done/tot*100):0;
    h+='<div class="tc"><div class="tt">'+dn.ic+' '+dn.ua+'</div>';
    h+='<div class="ts"><div class="tsb"><div class="tsv">'+pct+'%</div><div class="tsl">Виконання</div></div>';
    h+='<div class="tsb"><div class="tsv">'+(d.feel?d.feel.split(' ')[0]:'—')+'</div><div class="tsl">Самопочуття</div></div>';
    h+='<div class="tsb"><div class="tsv">'+done+'/'+tot+'</div><div class="tsl">Підходів</div></div></div>';
    ex.forEach(function(e,i){
      if(!e.hw)return;
      var dn2=d.sets[i]?d.sets[i].filter(function(s){return s==='done';}).length:0;
      h+='<div class="ter"><span class="ten">'+e.ua+'</span><span class="tev">'+d.w[i]+' кг · '+dn2+'/'+e.s+'</span></div>';
    });
    if(d.pain&&d.pain!=='Немає')h+='<div style="margin-top:8px;font-size:12px;color:var(--red)">Біль: '+d.pain+'</div>';
    if(d.note)h+='<div style="margin-top:6px;font-size:12px;color:var(--txt2)">'+d.note+'</div>';
    h+='</div>';
  });
  h+='<button class="btn-g" onclick="genW()">Тижневий звіт</button>';
  document.getElementById('main').innerHTML=h;
}
function esc(t){return t.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');}
load();rDay('tue');
