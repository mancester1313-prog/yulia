.hdr-meta{display:flex;gap:8px;margin-bottom:12px}
.badge{font-size:10px;color:rgba(255,255,255,.4);background:rgba(255,255,255,.07);padding:3px 10px;border-radius:var(--rp);border:1px solid var(--brd)}
