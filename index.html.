var DN={tue:{ua:'Вівторок — Верх тіла',ic:'💪'},thu:{ua:'Четвер — Ноги / Сідниці',ic:'🍑'},fri:{ua:'Пятниця — Верх тіла',ic:'🔄'},sun:{ua:'Неділя — Теніс',ic:'🎾'}};
function save(){try{localStorage.setItem('y8',JSON.stringify({d:S.d,wk:S.wk}));}catch(e){}}
function load(){try{var r=localStorage.getItem('y8');if(r){var p=JSON.parse(r);if(p.d)S.d=p.d;if(p.wk)S.wk=p.wk;}}catch(e){}}
function iDay(day){
  if(S.d[day])return;
  var ex=EX[day]||[];
  var o={feel:'',pain:'Немає',note:'',sets:{},w:{},reps:{}};
  ex.forEach(function(e,i){o.sets[i]=[];for(var s=0;s<e.s;s++)o.sets[i].push('');o.w[i]=e.dw;o.reps[i]=e.r;});
  S.d[day]=o;
}
var tI=null,tTot=90,tLeft=90,CIRC=2*Math.PI*60;
function startT(secs,name){
  tTot=secs;tLeft=secs;
  document.getElementById('tex').textContent=name;
  document.getElementById('tov').style.display='flex';
  updT();
  if(tI)clearInterval(tI);
  tI=setInterval(function(){
    tLeft--;updT();
    if(tLeft<=0){
      clearInterval(tI);
      document.getElementById('tnum').textContent='✓';
      document.getElementById('tmsg').textContent='Готово! Наступний підхід 🔥';
      try{if(navigator.vibrate)navigator.vibrate([200,100,200,100,400]);}catch(e){}
      setTimeout(function(){document.getElementById('tov').style.display='none';},1800);
    }
  },1000);
}
function updT(){
  document.getElementById('tnum').textContent=tLeft;
  var off=CIRC-(CIRC*(tLeft/tTot));
  document.getElementById('tarc').style.strokeDashoffset=off;
  var m=tLeft>tTot*.6?'Відпочивай 💪':tLeft>tTot*.3?'Майже готова! 🔥':'Ще трохи...';
  document.getElementById('tmsg').textContent=m;
}
function skipT(){if(tI)clearInterval(tI);document.getElementById('tov').style.display='none';}
function showToast(m){var t=document.getElementById('toast');t.textContent=m;t.classList.add('show');setTimeout(function(){t.classList.remove('show');},2200);}
function today(){var d=new Date();return d.getDate()+'.'+(d.getMonth()+1)+'.'+d.getFullYear();}
function sw(day,idx){
  document.querySelectorAll('.tab').forEach(function(t,i){t.classList.toggle('on',i===idx);});
  S.cur=day;
  if(day==='week')rWeek();else if(day==='prog')rProg();else rDay(day);
}
function goT(){rTrainer();document.querySelectorAll('.tab').forEach(function(t){t.classList.remove('on');});}
function rDay(day){
  iDay(day);
  var d=S.d[day],ex=EX[day]||[],dn=DN[day];
  var h='<div class="lbl">'+dn.ic+' '+dn.ua+'</div>';
  ex.forEach(function(e,i){
    var sets=d.sets[i]||[];
    var done=sets.filter(function(s){return s==='done';}).length;
    var all=done===sets.length&&sets.length>0,any=done>0;
    var sl=all?'<span class="ex-dl">V Виконано</span>':any?'<span class="ex-pl">~ В процесі</span>':'';
    var btns='';
    for(var s=0;s<e.s;s++){
      var st=sets[s];
      btns+='<button class="sb'+(st==='done'?' done':st==='fail'?' fail':'')+'" id="sb-'+day+'-'+i+'-'+s+'" onclick="tapS(\''+day+'\','+i+','+s+','+e.rs+',\''+e.ua.replace(/'/g,'`')+'\')">'+( s+1)+'</button>';
    }
    var wC=e.hw?'<div class="cb"><div class="cl">Вага (кг)</div><div class="ci"><button class="cm" onclick="chV(\'w\',\''+day+'\','+i+',-2.5)">-</button><div class="cv" id="wv-'+day+'-'+i+'">'+d.w[i]+'</div><button class="cm" onclick="chV(\'w\',\''+day+'\','+i+',2.5)">+</button></div></div>':'<div style="flex:1"></div>';
    var rL=day==='sun'?'Хвилин':'Повторень';
    var rv=typeof d.reps[i]==='number'?d.reps[i]:(parseFloat(d.reps[i])||1);
    var yt=e.yt?'<a class="yt" href="'+e.yt+'" target="_blank" rel="noopener">▶ Техніка</a>':'';
    h+='<div class="ex'+(all?' xdone':'')+'" id="exb-'+day+'-'+i+'">';
    h+='<div class="ex-nr"><div class="ex-n">Вправа '+e.n+'</div>'+sl+'</div>';
    h+='<div class="ex-ua">'+e.ua+'</div><div class="ex-ru">'+e.ru+'</div><div class="ex-mu">'+e.mu+'</div>';
    h+='<div class="ex-tags"><span class="tag">'+e.s+'x'+e.r+'</span><span class="tag">RIR '+e.ri+'</span><span class="tag g">'+e.tm+'</span><span class="tag">'+e.rs+' сек відп</span></div>';
    h+=yt;
    h+='<div class="sets-sec"><div class="sets-lbl">Підходи (тап = виконано):</div><div class="sets-row">'+btns+'</div></div>';
    h+='<div class="cr">'+wC+'<div class="cb"><div class="cl">'+rL+'</div><div class="ci"><button class="cm" onclick="chV(\'r\',\''+day+'\','+i+',-1)">-</button><div class="cv" id="rv-'+day+'-'+i+'">'+rv+'</div><button class="cm" onclick="chV(\'r\',\''+day+'\','+i+',1)">+</button></div></div></div>';
    h+='</div>';
  });
  h+='<div class="lbl">Як почувалась?</div><div class="card"><div class="feel-row" id="fl-'+day+'">';
  [['😴','Погано'],['😕','Так собі'],['😐','Норм'],['🙂','Добре'],['💪','Відмінно']].forEach(function(f){
    var a=d.feel===f[0]+' '+f[1]?' on':'';
    h+='<div class="fb'+a+'" onclick="pFeel(\''+day+'\',\''+f[0]+' '+f[1]+'\',this)"><span class="fi">'+f[0]+'</span><span class="fl">'+f[1]+'</span></div>';
  });
  h+='</div></div>';
  h+='<div class="lbl">Біль або дискомфорт?</div><div class="card"><div class="chips">';
  ['Немає','Коліна','Попереку','Плечі','Інше'].forEach(function(p){
    h+='<div class="chip'+(d.pain===p?' on':'')+'" onclick="pChip(\'pain\',\''+day+'\',\''+p+'\',this)">'+p+'</div>';
  });
  h+='</div></div>';
  h+='<div class="lbl">Нотатки для тренера</div>';
  h+='<div class="card"><textarea id="nt-'+day+'" rows="3" placeholder="Запитання, зауваження..." oninput="S.d[\''+day+'\'].note=this.value;save()">'+d.note+'</textarea></div>';
  document.getElementById('main').innerHTML=h;
}
function tapS(day,i,s,rs,name){
  var d=S.d[day];
  var cur=d.sets[i][s];
  var nxt=cur===''?'done':cur==='done'?'fail':'';
  d.sets[i][s]=nxt;
  var btn=document.getElementById('sb-'+day+'-'+i+'-'+s);
  if(btn)btn.className='sb'+(nxt==='done'?' done':nxt==='fail'?' fail':'');
  var all=d.sets[i].every(function(x){return x==='done';});
  var bl=document.getElementById('exb-'+day+'-'+i);
  if(bl)bl.classList.toggle('xdone',all);
  save();
  if(nxt==='done'&&rs>0)startT(rs,name);
  try{if(navigator.vibrate)navigator.vibrate(nxt==='done'?[40]:nxt==='fail'?[80,40,80]:[20]);}catch(e){}
}
function chV(tp,day,i,delta){
  var d=S.d[day];
  if(tp==='w'){d.w[i]=Math.max(0,Math.round((d.w[i]+delta)*2)/2);var el=document.getElementById('wv-'+day+'-'+i);if(el)el.textContent=d.w[i];}
  else{var c=typeof d.reps[i]==='number'?d.reps[i]:(parseFloat(d.reps[i])||1);d.reps[i]=Math.max(1,c+delta);var el2=document.getElementById('rv-'+day+'-'+i);if(el2)el2.textContent=d.reps[i];}
  save();
}
function pFeel(day,val,el){S.d[day].feel=val;document.getElementById('fl-'+day).querySelectorAll('.fb').forEach(function(b){b.classList.remove('on');});el.classList.add('on');save();}
function pChip(tp,day,val,el){S.d[day][tp]=val;el.parentNode.querySelectorAll('.chip').forEach(function(c){c.classList.remove('on');});el.classList.add('on');save();}
function rWeek(){
  var days=['tue','thu','fri','sun'];
  var h='<div class="lbl">Підсумок тренувань</div><div class="card">';
  days.forEach(function(day){
    iDay(day);
    var d=S.d[day],ex=EX[day]||[],dn=DN[day];
    var tot=0,done=0;
    ex.forEach(function(e,i){if(d.sets[i])d.sets[i].forEach(function(s){tot++;if(s==='done')done++;});});
    var pct=tot>0?Math.round(done/tot*100):0;
    var ic=pct>=80?'✅':pct>0?'⚡':'—';
    var cls=pct>=80?'wid':pct>0?'wip':'win';
    h+='<div class="wd"><div class="wi '+cls+'">'+ic+'</div><div class="wn"><div class="wname">'+dn.ic+' '+dn.ua+'</div><div class="wsub">'+done+'/'+tot+' підходів'+(d.feel?' · '+d.feel:'')+'</div><div class="pb"><div class="pf" style="width:'+pct+'%"></div></div></div><div class="wpct">'+pct+'%</div></div>';
  });
  h+='</div>';
  h+='<div class="lbl">Вага (кг)</div><div class="card card-g"><div class="bnr"><button class="bb" onclick="chW(-0.5)">-</button><div class="bv" id="ww-v">'+S.wk.w.toFixed(1)+'</div><span class="bu">кг</span><button class="bb" onclick="chW(0.5)">+</button></div></div>';
  h+='<div class="lbl">Самопочуття (1-10)</div><div class="card">';
  [['en','Енергія'],['sl','Сон'],['st','Стрес'],['mu','Втома']].forEach(function(r){
    h+='<div class="sl"><div class="slh"><span class="sln">'+r[1]+'</span><span class="slv" id="'+r[0]+'-v">'+S.wk[r[0]]+'</span></div><input type="range" min="1" max="10" step="1" value="'+S.wk[r[0]]+'" oninput="S.wk[\''+r[0]+'\']=+this.value;document.getElementById(\''+r[0]+'-v\').textContent=this.value;save()"></div>';
  });
  h+='</div>';
  h+='<div class="lbl">Настрій тижня</div><div class="card"><div class="feel-row" id="mood-r">';
  [['😞','Погано'],['😕','Так собі'],['😐','Норм'],['🙂','Добре'],['😄','Чудово']].forEach(function(f){
    var a=S.wk.mood===f[0]+' '+f[1]?' on':'';
    h+='<div class="fb'+a+'" onclick="pMood(\''+f[0]+' '+f[1]+'\',this)"><span class="fi">'+f[0]+'</span><span class="fl">'+f[1]+'</span></div>';
  });
  h+='</div></div>';
  h+='<button class="btn-g" onclick="genW()">Сформувати тижневий звіт</button>';
  document.getElementById('main').innerHTML=h;
}
function chW(d){S.wk.w=Math.max(40,Math.round((S.wk.w+d)*10)/10);var el=document.getElementById('ww-v');if(el)el.textContent=S.wk.w.toFixed(1);save();}
function pMood(val,el){S.wk.mood=val;document.getElementById('mood-r').querySelectorAll('.fb').forEach(function(b){b.classList.remove('on');});el.classList.add('on');save();}
function genW(){
  var days=['tue','thu','fri','sun'];
  var t='ТИЖНЕВИЙ ЗВІТ — ЮЛЯ\n';
  t+='━━━━━━━━━━━━━━━━━\n';
  t+='Дата: '+today()+' | Тиждень '+W+'\n\n';
  t+='ТРЕНУВАННЯ:\n';
  days.forEach(function(day){
    iDay(day);
    var d=S.d[day],ex=EX[day]||[],dn=DN[day];
    var tot=0,done=0;
    ex.forEach(function(e,i){if(d.sets[i])d.sets[i].forEach(function(s){tot++;if(s==='done')done++;});});
    var pct=tot>0?Math.round(done/tot*100):0;
    t+=dn.ic+' '+dn.ua+': '+done+'/'+tot+' ('+pct+'%)'+(d.feel?' · '+d.feel:'')+'\n';
    ex.forEach(function(e,i){
      if(!e.hw)return;
      var dn2=d.sets[i]?d.sets[i].filter(function(s){return s==='done';}).length:0;
      t+='   '+e.ua+': '+d.w[i]+' кг | '+dn2+'/'+e.s+' підх\n';
    });
    if(d.pain&&d.pain!=='Немає')t+='   Біль: '+d.pain+'\n';
    if(d.note)t+='   Нотатки: '+d.note+'\n';
    t+='\n';
  });
  var wk=S.wk;
  t+='Вага: '+wk.w.toFixed(1)+' кг\n\n';
  t+='Самопочуття:\n';
  t+='   Енергія: '+wk.en+'/10 | Сон: '+wk.sl+'/10\n';
  t+='   Стрес: '+wk.st+'/10 | Втома: '+wk.mu+'/10\n\n';
  t+='Настрій: '+(wk.mood||'—')+'\n';
  t+='━━━━━━━━━━━━━━━━━\n';
  t+='Щоденник Юлі · Тиждень '+W;
  showRep(t,'week');
}
function showRep(txt,tp){
  S.rt=tp;
  var tg='https://t.me/share/url?url=&text='+encodeURIComponent(txt);
  var wa='https://wa.me/?text='+encodeURIComponent(txt);
