.hdr-lbl{font-size:10px;letter-spacing:.1em;color:rgba(255,255,255,.4);text-transform:uppercase;margin-left:7px}
.hdr-brand{display:flex;align-items:center}
.hdr-act{display:flex;gap:8px}
.hdr-btn{width:34px;height:34px;border-radius:50%;background:rgba(255,255,255,.08);border:1px solid var(--brd);display:flex;align-items:center;justify-content:center;font-size:16px;cursor:pointer}
.hdr-name{font-size:22px;font-weight:700;color:#fff;margin-bottom:4px}
