.tarc{stroke:var(--gold);stroke-linecap:round;transition:stroke-dashoffset 1s linear}
.tinn{position:absolute;top:0;left:0;width:130px;height:130px;display:flex;flex-direction:column;align-items:center;justify-content:center}
